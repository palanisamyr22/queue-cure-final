# Frontend Environment Variables Example
# Copy this file to .env and configure the URLs to point to your backend.

# The REST API endpoint.
# Local Development: http://localhost:8000
# Production: https://your-backend.onrender.com
VITE_API_URL=http://localhost:8000

# The WebSocket connection endpoint.
# Local Development: ws://localhost:8000/ws/queue
# Production: wss://your-backend.onrender.com/ws/queue
VITE_WS_URL=ws://localhost:8000/ws/queue
