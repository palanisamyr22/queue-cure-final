# Backend Environment Variables Example
# Copy this file to .env and adjust for local or production use.

# The SQLite database path. 
# For Render, this points to the persistent disk mount path.
DATABASE_URL=sqlite:///./queue_cure.db

# Comma-separated list of allowed origins for CORS.
# E.g., http://localhost:5173,https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:5173,*
